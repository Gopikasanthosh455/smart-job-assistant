# Copy this file to .env and fill in your values
# Never commit .env to GitHub!

# Get your free key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Django secret key (change this to something random in production)
SECRET_KEY=django-insecure-change-this-to-something-random

# PostgreSQL (only needed when deploying — SQLite works for local dev)
# DB_NAME=jobassistant_db
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432
